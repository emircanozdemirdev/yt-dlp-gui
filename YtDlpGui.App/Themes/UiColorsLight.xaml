<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ColorBg">#FFF4F4F5</Color>
    <Color x:Key="ColorCard">#FFFFFFFF</Color>
    <Color x:Key="ColorSurface">#FFFFFFFF</Color>
    <Color x:Key="ColorBorder">#FFE4E4E7</Color>
    <Color x:Key="ColorBorderSubtle">#FFF4F4F5</Color>
    <Color x:Key="ColorText">#FF18181B</Color>
    <Color x:Key="ColorMuted">#FF71717A</Color>
    <Color x:Key="ColorAccent">#FF4F46E5</Color>
    <Color x:Key="ColorAccentHover">#FF6366F1</Color>
    <Color x:Key="ColorGridHeader">#FFF4F4F5</Color>
    <Color x:Key="ColorGridAlt">#FFFAFAFA</Color>
    <Color x:Key="ColorTabBar">#FFEBEBEF</Color>
    <Color x:Key="ColorTabHover">#FFE4E4E7</Color>
    <Color x:Key="ColorTabSelected">#FFFFFFFF</Color>
    <Color x:Key="ColorComboBoxItemHighlight">#FFEEF2FF</Color>

    <SolidColorBrush x:Key="BrushBg" Color="{StaticResource ColorBg}"/>
    <SolidColorBrush x:Key="BrushCard" Color="{StaticResource ColorCard}"/>
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurface}"/>
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BrushBorderSubtle" Color="{StaticResource ColorBorderSubtle}"/>
    <SolidColorBrush x:Key="BrushText" Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="BrushMuted" Color="{StaticResource ColorMuted}"/>
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="BrushAccentHover" Color="{StaticResource ColorAccentHover}"/>
    <SolidColorBrush x:Key="BrushGridHeader" Color="{StaticResource ColorGridHeader}"/>
    <SolidColorBrush x:Key="BrushGridAlt" Color="{StaticResource ColorGridAlt}"/>
    <SolidColorBrush x:Key="BrushTabBar" Color="{StaticResource ColorTabBar}"/>
    <SolidColorBrush x:Key="BrushTabHover" Color="{StaticResource ColorTabHover}"/>
    <SolidColorBrush x:Key="BrushTabSelected" Color="{StaticResource ColorTabSelected}"/>
    <SolidColorBrush x:Key="BrushComboBoxItemHighlight" Color="{StaticResource ColorComboBoxItemHighlight}"/>
</ResourceDictionary>
