<Window x:Class="YtDlpGui.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="yt-dlp GUI"
        Background="{DynamicResource BrushBg}"
        Foreground="{DynamicResource BrushText}"
        Height="780"
        Width="1120"
        MinWidth="1000"
        MinHeight="700">
    <Window.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{DynamicResource ColorText}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{DynamicResource ColorText}"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{DynamicResource ColorMuted}"/>
    </Window.Resources>
    <Grid Margin="20,16" Background="{DynamicResource BrushBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="yt-dlp GUI" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
            <TextBlock Text="Analyze a URL, pick a format, queue downloads." FontSize="13"
                       Foreground="{DynamicResource BrushMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Quick Download">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Video URL" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                            <TextBox Grid.Row="1" Grid.Column="0" Margin="0,8,12,0" MinHeight="40"
                                     Text="{Binding QuickDownload.Url, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Row="1" Grid.Column="1" VerticalAlignment="Bottom" MinWidth="120" Content="Analyze"
                                    Command="{Binding QuickDownload.AnalyzeCommand}"/>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,16,0,0">
                                <TextBlock Text="{Binding QuickDownload.Title}" FontSize="17" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Foreground="{DynamicResource BrushText}"/>
                                <TextBlock Text="{Binding QuickDownload.Uploader}" Margin="0,4,0,0"
                                           Foreground="{DynamicResource BrushMuted}"/>
                                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource BrushMuted}">
                                    <Run Text="Duration: "/>
                                    <Run Text="{Binding QuickDownload.Duration}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Margin="0,16,0,0" Background="{DynamicResource BrushSurface}"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Formats (best -> lowest)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushText}" Margin="0,0,0,8"/>

                            <DataGrid Grid.Row="1" MinHeight="220"
                                      ItemsSource="{Binding QuickDownload.Formats}"
                                      SelectedItem="{Binding QuickDownload.SelectedFormat}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Type" Binding="{Binding MediaKind}" Width="72"/>
                                    <DataGridTextColumn Header="Format" Binding="{Binding FormatId}" Width="88"/>
                                    <DataGridTextColumn Header="Ext" Binding="{Binding Extension}" Width="56"/>
                                    <DataGridTextColumn Header="Resolution" Binding="{Binding Resolution}" Width="120"/>
                                    <DataGridTextColumn Header="Codec" Binding="{Binding Codec}" Width="*"/>
                                    <DataGridTextColumn Header="Bitrate" Binding="{Binding Bitrate}" Width="88"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="2" Margin="0,14,0,0" Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Text="Preset" Foreground="{DynamicResource BrushMuted}"/>
                                <ComboBox Width="200" Margin="10,0,0,0"
                                          ItemsSource="{Binding QuickDownload.Presets}"
                                          SelectedItem="{Binding QuickDownload.QuickPreset}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushText}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button MinWidth="140" Margin="14,0,0,0" Content="Download"
                                        Command="{Binding QuickDownload.EnqueueDownloadCommand}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Margin="0,10,0,0" FontStyle="Italic"
                                       Foreground="{DynamicResource BrushMuted}"
                                       Text="{Binding QuickDownload.StatusMessage}" TextWrapping="Wrap"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Queue">
                <Border Margin="0,12,0,0" Background="{DynamicResource BrushSurface}"
                        BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="12">
                    <DataGrid ItemsSource="{Binding Queue.Jobs}" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="220"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Progress %" Binding="{Binding ProgressPercent, StringFormat={}{0:0.#}}" Width="96"/>
                            <DataGridTextColumn Header="Speed" Binding="{Binding SpeedText}" Width="100"/>
                            <DataGridTextColumn Header="ETA" Binding="{Binding EtaText}" Width="88"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            <DataGridTemplateColumn Header="" Width="108">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SecondaryButton}" Content="Cancel"
                                                Command="{Binding DataContext.Queue.CancelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" Padding="12,6" MinHeight="32"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="History">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" MinWidth="120" Content="Refresh"
                            Command="{Binding History.RefreshCommand}"/>
                    <Border Grid.Row="1" Margin="0,12,0,0" Background="{DynamicResource BrushSurface}"
                            BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="12">
                        <DataGrid ItemsSource="{Binding History.Items}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="260"/>
                                <DataGridTextColumn Header="Output" Binding="{Binding OutputPath}" Width="*"/>
                                <DataGridTextColumn Header="OK" Binding="{Binding IsSuccess}" Width="56"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="200"/>
                                <DataGridTextColumn Header="When (UTC)" Binding="{Binding CompletedAtUtc}" Width="168"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <Border Background="{DynamicResource BrushSurface}" BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1" CornerRadius="8" Padding="20" MaxWidth="720" HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Output folder"
                                       Foreground="{DynamicResource BrushMuted}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="12,6,0,6" MinHeight="40"
                                     Text="{Binding Settings.OutputDirectoryDisplay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Filename template"
                                       Foreground="{DynamicResource BrushMuted}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="12,6,0,6" MinHeight="40"
                                     Text="{Binding Settings.Current.FileNameTemplate, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Max parallel"
                                       Foreground="{DynamicResource BrushMuted}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Margin="12,6,0,6" MinHeight="40"
                                     Text="{Binding Settings.MaxParallelDownloadsInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Retries"
                                       Foreground="{DynamicResource BrushMuted}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="12,6,0,6" MinHeight="40"
                                     Text="{Binding Settings.RetriesInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Proxy"
                                       Foreground="{DynamicResource BrushMuted}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="12,6,0,6" MinHeight="40"
                                     Text="{Binding Settings.Current.Proxy, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Theme"
                                       Foreground="{DynamicResource BrushMuted}"/>
                            <ComboBox Grid.Row="5" Grid.Column="1" Margin="12,6,0,6"
                                      ItemsSource="{Binding Settings.ThemeOptions}"
                                      SelectedItem="{Binding Settings.SelectedTheme, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrushText}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Margin="0,12,0,0" Orientation="Horizontal">
                                <Button Style="{StaticResource SecondaryButton}" MinWidth="120" Content="Save"
                                        Command="{Binding Settings.SaveCommand}"/>
                                <TextBlock Margin="14,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushMuted}"
                                           Text="{Binding Settings.StatusMessage}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

